// Prisma schema for SORT v2 - RBAC Authentication

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
  MRF
}

enum ReportStatus {
  PENDING
  VERIFIED
  DISMISSED
  DISPATCHED
  IN_PROGRESS
  COMPLETED
  COLLECTED
  RESOLVED
}

enum ReportType {
  WASTE
  ASSET
}

enum LocationType {
  BIN_LOCATION
  ROOM_LOCATION
}

model User {
  id       String @id @default(cuid())
  username String @unique
  password String
  role     Role   @default(STUDENT)

  // Profile info
  firstName String?
  lastName  String?
  email     String? @unique

  // Student-specific fields
  studentId  String? @unique
  course     String?
  section    String?
  department String?

  // Gamification
  points  Int @default(0)
  reports Int @default(0)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  submittedReports Report[]     @relation("UserReports")
  assignedReports  Report[]     @relation("AssignedStaffReports")
  newsPosts        CampusNews[] @relation("PublishedNews")

  @@map("users")
}

model Report {
  id        String       @id @default(cuid())
  location  String
  notes     String?
  photoUrl  String?
  urgency   String       @default("normal")
  wasteType String       @default("general")
  type      ReportType   @default(WASTE)
  status    ReportStatus @default(PENDING)

  // MRF Operations fields
  assignedStaffId String?
  kilosCollected  Float?
  collectionDate  DateTime?

  // User relation
  userId        String
  user          User   @relation("UserReports", fields: [userId], references: [id], onDelete: Cascade)
  assignedStaff User?  @relation("AssignedStaffReports", fields: [assignedStaffId], references: [id], onDelete: SetNull)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([assignedStaffId])
  @@index([type, status])
  @@map("reports")
}

model CampusNews {
  id            String   @id @default(cuid())
  tag           String
  date          String
  title         String
  desc          String
  publishedById String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  publishedBy User? @relation("PublishedNews", fields: [publishedById], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([publishedById])
  @@map("campus_news")
}

model AssetCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  label     String
  enabled   Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  itemPresets ItemPreset[] @relation("CategoryPresets")

  @@index([enabled, sortOrder])
  @@map("asset_categories")
}

model ItemPreset {
  id         String   @id @default(cuid())
  name       String
  icon       String   @default("📦")
  categoryId String
  enabled    Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category AssetCategory @relation("CategoryPresets", fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId, enabled, sortOrder])
  @@map("item_presets")
}

model Location {
  id        String       @id @default(cuid())
  code      String       @unique // e.g., LOC-01, ROOM-01
  name      String
  type      LocationType
  building  String? // For ROOM_LOCATION, which building it belongs to
  enabled   Boolean      @default(true)
  sortOrder Int          @default(0)

  // Map coordinates for visual representation
  mapX Float?
  mapY Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, enabled, sortOrder])
  @@map("locations")
}

model CampusMap {
  id           String   @id @default(cuid())
  imageData    String   @db.Text // Base64 encoded image
  imageName    String?
  imageSize    String?
  uploadedById String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("campus_maps")
}

model BinStatus {
  id          String   @id @default(cuid())
  locationId  String   @unique // References Location.id
  fillStatus  String   @default("empty") // empty, half, full
  lastUpdated DateTime @default(now())
  updatedBy   String? // User ID who updated the status

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fillStatus])
  @@map("bin_statuses")
}
